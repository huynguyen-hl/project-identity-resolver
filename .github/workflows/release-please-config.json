{
  "packages": {
    ".": {
      "release-type": "simple",
      "versioning": "default",
      "extra-files": [
        {
          "type": "json",
          "path": "version.json",
          "jsonpath": "$.version"
        }
      ],
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features",
          "hidden": false
        },
        {
          "type": "fix",
          "section": "Bug Fixes",
          "hidden": false
        },
        {
          "type": "added",
          "section": "Added",
          "hidden": false
        },
        {
          "type": "changed",
          "section": "Changed",
          "hidden": false
        },
        {
          "type": "removed",
          "section": "Removed",
          "hidden": false
        }
      ]
    }
  }
}