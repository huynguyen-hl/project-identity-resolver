{
  "bootstrap-sha": "90ecef8e0648923e1ebf1e0b43feac779ebe3338",
  "plugins": ["node-workspace", "sentence-case"],
  "prerelease": true,
  "always-update": true,
  "pull-request-header": "🤖 I have generated a release changelog",
  "pull-request-footer": "This PR was automatically generated by 🤖.",

  "include-component-in-tag": false,
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features",
          "hidden": false,
          "type-plural": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes",
          "hidden": false,
          "type-plural": "Bug Fixes"
        },
        {
          "type": "refactor",
          "section": "Code Refactoring",
          "hidden": false,
          "type-plural": "Code Refactoring"
        },
        {
          "type": "test",
          "section": "Tests",
          "hidden": false,
          "type-plural": "Tests"
        },
        {
          "type": "changed",
          "section": "Changed",
          "hidden": false,
          "type-plural": "Changes"
        },
        {
          "type": "docs",
          "section": "Documentation",
          "hidden": false,
          "type-plural": "Documentation"
        },
        {
          "type": "chore",
          "section": "Miscellaneous",
          "hidden": false,
          "type-plural": "Chores"
        }
      ]
    }
  }
}