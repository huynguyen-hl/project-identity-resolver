{
  "bootstrap-sha": "ae5692d4846dc94dd40e226dad3aa9489990677a",
  "plugins": ["node-workspace", "sentence-case"],
  "prerelease": true,
  "always-update": true,

  "include-component-in-tag": false,
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features",
          "hidden": false,
          "type-plural": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes",
          "hidden": false,
          "type-plural": "Bug Fixes"
        },
        {
          "type": "refactor",
          "section": "Code Refactoring",
          "hidden": false,
          "type-plural": "Code Refactoring"
        },
        {
          "type": "test",
          "section": "Tests",
          "hidden": false,
          "type-plural": "Tests"
        },
        {
          "type": "changed",
          "section": "Changed",
          "hidden": false,
          "type-plural": "Changes"
        },
        {
          "type": "docs",
          "section": "Documentation",
          "hidden": false,
          "type-plural": "Documentation"
        },
        {
          "type": "chore",
          "section": "Miscellaneous",
          "hidden": false,
          "type-plural": "Chores"
        }
      ]
    }
  }
}